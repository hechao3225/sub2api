# Sub2API private deployment for ai.toolmate.cn
# Copy to .env and replace every CHANGE_ME value before starting.
TZ=Asia/Shanghai
BIND_HOST=127.0.0.1
SERVER_PORT=8080
SERVER_MODE=release
RUN_MODE=standard

# Pin the application release; do not use latest in production.
SUB2API_IMAGE=ghcr.io/hechao3225/sub2api:0.1.161-aimate.1
POSTGRES_IMAGE=postgres:18-alpine
REDIS_IMAGE=redis:8-alpine

POSTGRES_USER=sub2api
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=sub2api
DATABASE_MAX_OPEN_CONNS=20
DATABASE_MAX_IDLE_CONNS=5
DATABASE_CONN_MAX_LIFETIME_MINUTES=30
DATABASE_CONN_MAX_IDLE_TIME_MINUTES=5

REDIS_PASSWORD=CHANGE_ME
REDIS_DB=0
REDIS_MAXCLIENTS=256
REDIS_POOL_SIZE=64
REDIS_MIN_IDLE_CONNS=4

ADMIN_EMAIL=admin@toolmate.cn
ADMIN_PASSWORD=CHANGE_ME
JWT_SECRET=CHANGE_ME
TOTP_ENCRYPTION_KEY=CHANGE_ME

# The admin UI is used to turn off public registration/payment/affiliate features.
SECURITY_URL_ALLOWLIST_ENABLED=false
SECURITY_URL_ALLOWLIST_ALLOW_INSECURE_HTTP=false
SECURITY_URL_ALLOWLIST_ALLOW_PRIVATE_HOSTS=false
GATEWAY_OPENAI_RESPONSE_HEADER_TIMEOUT=0
GATEWAY_OPENAI_HTTP2_ENABLED=true
GATEWAY_OPENAI_HTTP2_ALLOW_PROXY_FALLBACK_TO_HTTP1=true
LOG_LEVEL=info
LOG_FORMAT=json
LOG_ENV=production
LOG_OUTPUT_TO_STDOUT=true
LOG_OUTPUT_TO_FILE=true
LOG_ROTATION_MAX_SIZE_MB=50
LOG_ROTATION_MAX_BACKUPS=5
LOG_ROTATION_MAX_AGE_DAYS=7
LOG_ROTATION_COMPRESS=true
